{
  "name": "boilerplate-backend-flue",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Restack/Temporal backend re-implemented on Flue + Cloudflare (Workers, Durable Objects, D1, Analytics Engine, Vectorize).",
  "scripts": {
    "dev": "flue dev",
    "dev:backend": "flue dev",
    "dev:frontend": "pnpm --filter boilerplate-frontend dev",
    "build:backend": "flue build --target cloudflare",
    "build:frontend": "pnpm --filter boilerplate-frontend build",
    "build:frontend:cloudflare": "pnpm --filter boilerplate-frontend build:cloudflare",
    "build": "flue build --target cloudflare",
    "deploy:backend": "flue build --target cloudflare && wrangler deploy --config dist/boilerplate_backend/wrangler.json",
    "deploy:frontend": "pnpm --filter boilerplate-frontend build:cloudflare && wrangler deploy --config apps/frontend/wrangler.jsonc",
    "deploy": "pnpm deploy:backend && pnpm deploy:frontend",
    "typecheck": "tsc --noEmit",
    "typecheck:frontend": "pnpm --filter boilerplate-frontend type-check",
    "db:create": "wrangler d1 create boilerplate-db",
    "db:migrate": "wrangler d1 migrations apply DB --remote",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:seed:admin": "node scripts/seed-admin.mjs"
  },
  "dependencies": {
    "@flue/runtime": "^1.0.0-beta.9",
    "@flue/slack": "^1.0.0-beta.1",
    "agents": "^0.1.0",
    "hono": "^4.6.0",
    "valibot": "^1.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260601.0",
    "@flue/cli": "^1.0.0-beta.9",
    "typescript": "^5.6.0",
    "wrangler": "^4.0.0"
  }
}
